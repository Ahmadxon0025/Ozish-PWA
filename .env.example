# ─────────────────────────────────────────────────────────────────────────────
# Tier 3 (ixtiyoriy / optional) — serverless backend environment variables.
# These live ONLY on the server (Vercel → Project → Settings → Environment
# Variables). They are NEVER shipped to the browser. If they are missing the
# app silently hides Tier 3 and Tiers 1–2 keep working forever.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude) — powers the AI coach and Uzbek food-sentence parsing.
# Get it at https://console.anthropic.com → API Keys. See SETUP.md §1.
ANTHROPIC_API_KEY=

# Speech-to-text provider: "yandex" (default, best Uzbek support) or "google".
STT_PROVIDER=yandex

# Yandex SpeechKit — service-account API key. See SETUP.md §2.
YANDEX_API_KEY=

# Google Cloud Speech-to-Text — API key (fallback provider). See SETUP.md §3.
GOOGLE_SPEECH_API_KEY=
