# ============================================================================
# Shahnoza Dashboard — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the deployment (used for OAuth redirect + magic-link).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# Used by the Supabase CLI for migrations (not read by the app at runtime).
SUPABASE_DB_PASSWORD=

# --- Telegram ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_OWNER_CHAT_ID=987654321
# Group chat that receives the daily finance report + accepts "rasxod ..." commands.
# Get it by typing /id in the group after the bot is a member.
TELEGRAM_FINANCE_CHAT_ID=-1001234567890
# Random string echoed back by Telegram on every webhook call (openssl rand -hex 16).
TELEGRAM_WEBHOOK_SECRET=change-me

# --- AmoCRM ------------------------------------------------------------------
AMOCRM_SUBDOMAIN=shahnoza
AMOCRM_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AMOCRM_CLIENT_SECRET=xxxxxx...
# Redirect URI registered in the amoCRM integration:
#   {NEXT_PUBLIC_APP_URL}/api/auth/amocrm/callback

# --- Cron / internal auth -----------------------------------------------------
# Random secret. Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=change-me-to-a-long-random-string

# 32-byte base64 key used to encrypt integration tokens at rest.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=change-me-32-byte-base64-key

# --- Business defaults --------------------------------------------------------
# Fallback UZS→USD rate used only when a sale has no explicit USD amount.
NEXT_PUBLIC_UZS_PER_USD=12900
